{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start Server",
      "program": "${workspaceFolder}/server.js",
      "console": "integratedTerminal",
      "restart": true,
      "url": "http://localhost:3000",
      "serverReadyAction": {
        "pattern": "listening on port (\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ]
}
